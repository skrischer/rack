{
  "enabledPlugins": {
    "loopkit@loopkit": true
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": ["Bash", "WebFetch", "WebSearch"],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(supabase db reset)",
      "Bash(supabase db reset *)"
    ]
  }
}
