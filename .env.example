# Rack — environment template. Copy to `.env` and fill real values.
# `.env` is gitignored; never commit real secrets.

# --- Supabase project (shared) ---
# From the Supabase dashboard: Project Settings -> API.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>            # safe for the Android client
SUPABASE_PROJECT_REF=<project-ref>             # for the Supabase CLI (link/db push)

# --- rack-MCP (server-side only, VPS) ---
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # NEVER ships to the app
SUPABASE_JWT_SECRET=<project-jwt-secret>       # to mint user-scoped tokens for RLS
API_KEY_PEPPER=<random-long-string>            # pepper for hashing MCP API keys
MCP_PORT=8787
MCP_PUBLIC_URL=https://<your-vps-domain>       # behind Caddy (TLS)

# --- Supabase CLI (migrations) ---
SUPABASE_ACCESS_TOKEN=<personal-access-token>  # for `supabase link` / `db push`
SUPABASE_DB_PASSWORD=<db-password>

# --- Android app ---
# These two go into android/local.properties (gitignored), not a runtime .env:
#   supabase.url=${SUPABASE_URL}
#   supabase.anonKey=${SUPABASE_ANON_KEY}
